{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/frontend/",
            "permanent": false
        }
    ]
}